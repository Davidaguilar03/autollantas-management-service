<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.autollantas.gestion.shared.controller.DialogTestController"
           stylesheets="@../../styles/styles.css">

    <VBox alignment="CENTER" spacing="32" maxWidth="520">

        <Label text="Prueba de Dialogs" styleClass="lbl-titulo" />

        <Label text="Haz clic en cada botón para ver el dialog correspondiente."
               wrapText="true" style="-fx-font-size:13px; -fx-text-fill:#6b7280; -fx-text-alignment:center;" />

        <FlowPane hgap="12" vgap="12" alignment="CENTER">

            <Button text="ℹ  Info"
                    styleClass="btn-primary"
                    onAction="#showInfo"
                    prefWidth="140" prefHeight="42" />

            <Button text="✓  Éxito"
                    styleClass="btn-success"
                    onAction="#showSuccess"
                    prefWidth="140" prefHeight="42" />

            <Button text="!  Advertencia"
                    styleClass="btn-warning"
                    onAction="#showWarning"
                    prefWidth="140" prefHeight="42" />

            <Button text="?  Confirmar"
                    onAction="#showConfirm"
                    prefWidth="140" prefHeight="42"
                    style="-fx-background-color:#6366f1; -fx-text-fill:white; -fx-background-radius:8; -fx-font-size:13px; -fx-font-weight:bold; -fx-cursor:hand;" />

            <Button text="✕  Eliminar"
                    styleClass="btn-danger"
                    onAction="#showDanger"
                    prefWidth="140" prefHeight="42" />

        </FlowPane>

        <Label fx:id="lblResultado"
               text=""
               style="-fx-font-size:13px; -fx-text-fill:#374151; -fx-font-style:italic;" />

        <VBox.margin>
            <Insets top="40" />
        </VBox.margin>
    </VBox>

</StackPane>
