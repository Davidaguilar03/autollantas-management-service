<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import com.autollantas.gestion.shared.util.StyledTableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="modal-overlay" stylesheets="@../../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.inventory.controller.CategoryManagementController">

    <VBox alignment="TOP_CENTER" maxHeight="600" maxWidth="700" spacing="15" styleClass="card-form">
        <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="20.0" />
        </padding>

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="2">
                <Label styleClass="lbl-titulo" text="Gestión de Categorías" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#cerrarVentana" styleClass="btn-cerrar" text="✕" />
        </HBox>

        <Separator style="-fx-opacity: 0.5;" />

        <StyledTableView fx:id="tableCategories" style="-fx-fixed-cell-size: 44px;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="400.0" style="-fx-alignment: CENTER;" text="Nombre" />
                <TableColumn fx:id="colProductCount" prefWidth="350.0" style="-fx-alignment: CENTER;" text="Productos Asociados" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </StyledTableView>

        <HBox spacing="10.0">
            <Button contentDisplay="LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                    onAction="#onNueva" prefHeight="48.0"
                    styleClass="mini-card-btn,mini-card-green" text="Nueva Categoría">
                <graphic>
                    <StackPane alignment="CENTER" minWidth="30.0" minHeight="30.0" maxWidth="30.0" maxHeight="30.0"
                               styleClass="mini-card-chip-green">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="＋" StackPane.alignment="CENTER" />
                    </StackPane>
                </graphic>
            </Button>
            <Button fx:id="btnEditar" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                    mnemonicParsing="false" onAction="#onEditar" prefHeight="48.0"
                    styleClass="mini-card-btn,mini-card-orange" text="Editar">
                <graphic>
                    <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                               styleClass="mini-card-chip-orange">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✎" StackPane.alignment="CENTER" />
                    </StackPane>
                </graphic>
            </Button>
            <Button fx:id="btnEliminar" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                    mnemonicParsing="false" onAction="#onEliminar" prefHeight="48.0"
                    styleClass="mini-card-btn,mini-card-red" text="Eliminar">
                <graphic>
                    <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                               styleClass="mini-card-chip-red">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✕" StackPane.alignment="CENTER" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>

    </VBox>
</StackPane>
