<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import com.autollantas.gestion.shared.util.StyledTableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="modal-overlay" stylesheets="@../../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.inventory.controller.TaxManagementController">

    <VBox alignment="TOP_CENTER" maxHeight="720" maxWidth="980" spacing="15" styleClass="card-form">
        <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="20.0" />
        </padding>

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="2">
                <Label styleClass="lbl-titulo" text="Gestión de Impuestos" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#cerrarVentana" styleClass="btn-cerrar" text="✕" />
        </HBox>

        <Separator style="-fx-opacity: 0.5;" />

        <HBox spacing="15.0" VBox.vgrow="ALWAYS">
            <children>

                <!-- Sección izquierda: Tipos de Impuesto -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="Tipos de Impuesto" />

                        <StyledTableView fx:id="tableTaxTypes" style="-fx-fixed-cell-size: 44px;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTaxName" prefWidth="135.0" style="-fx-alignment: CENTER;" text="Nombre" />
                                <TableColumn fx:id="colTaxRate" prefWidth="85.0" style="-fx-alignment: CENTER;" text="Tasa %" />
                                <TableColumn fx:id="colTaxApplies" prefWidth="115.0" style="-fx-alignment: CENTER;" text="Aplica a" />
                                <TableColumn fx:id="colTaxDesc" prefWidth="245.0" style="-fx-alignment: CENTER;" text="Descripción" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </StyledTableView>

                        <HBox spacing="10.0">
                            <children>
                                <Button fx:id="btnNewTax" contentDisplay="LEFT" graphicTextGap="12.0"
                                        mnemonicParsing="false" onAction="#onNewTax" prefHeight="48.0"
                                        styleClass="mini-card-btn,mini-card-green" text="Nuevo Impuesto">
                                    <graphic>
                                        <StackPane alignment="CENTER" minWidth="30.0" minHeight="30.0" maxWidth="30.0" maxHeight="30.0"
                                                   styleClass="mini-card-chip-green">
                                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="＋" StackPane.alignment="CENTER" />
                                        </StackPane>
                                    </graphic>
                                </Button>
                                <Button fx:id="btnEditTax" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                                        mnemonicParsing="false" onAction="#onEditTax" prefHeight="48.0"
                                        styleClass="mini-card-btn,mini-card-orange" text="Editar">
                                    <graphic>
                                        <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                                   styleClass="mini-card-chip-orange">
                                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✎" StackPane.alignment="CENTER" />
                                        </StackPane>
                                    </graphic>
                                </Button>
                                <Button fx:id="btnDeleteTax" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                                        mnemonicParsing="false" onAction="#onDeleteTax" prefHeight="48.0"
                                        styleClass="mini-card-btn,mini-card-red" text="Eliminar">
                                    <graphic>
                                        <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                                   styleClass="mini-card-chip-red">
                                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✕" StackPane.alignment="CENTER" />
                                        </StackPane>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Sección derecha: Impuestos por Categoría -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" text="Impuestos por Categoría" />

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label style="-fx-text-fill: #555;" text="Categoría:" />
                                <ComboBox fx:id="comboCategoryTax" maxWidth="Infinity" promptText="Seleccionar categoría" styleClass="combo-box" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                        <StyledTableView fx:id="tableCategoryTaxes" editable="true" style="-fx-fixed-cell-size: 44px;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colCatTaxCheck" editable="true" prefWidth="70.0" style="-fx-alignment: CENTER;" text="Aplica" />
                                <TableColumn fx:id="colCatTaxName" prefWidth="150.0" style="-fx-alignment: CENTER;" text="Nombre" />
                                <TableColumn fx:id="colCatTaxRate" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Tasa %" />
                                <TableColumn fx:id="colCatTaxApplies" prefWidth="130.0" style="-fx-alignment: CENTER;" text="Aplica a" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </StyledTableView>

                        <HBox alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnSaveAssignment" contentDisplay="LEFT" graphicTextGap="12.0"
                                        mnemonicParsing="false" onAction="#onSaveAssignment" prefHeight="48.0"
                                        styleClass="mini-card-btn,mini-card-blue" text="Guardar Asignación">
                                    <graphic>
                                        <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                                   styleClass="mini-card-chip-blue">
                                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✓" StackPane.alignment="CENTER" />
                                        </StackPane>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </HBox>
    </VBox>
</StackPane>
