<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import com.autollantas.gestion.shared.util.StyledTableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0"
    style="-fx-background-color: #f0f2f5;"
    styleClass="main-background"
    stylesheets="@../../styles/styles.css"
    xmlns="http://javafx.com/javafx/25"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.autollantas.gestion.inventory.controller.TaxManagementController">

    <VBox spacing="16.0"
          AnchorPane.topAnchor="15" AnchorPane.bottomAnchor="15"
          AnchorPane.leftAnchor="18" AnchorPane.rightAnchor="18">
        <children>

            <Label text="Impuestos y Márgenes"
                   styleClass="view-title" />

            <Separator />

            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                <tabs>

                    <!-- PESTAÑA 1: Impuestos -->
                    <Tab text="Impuestos">
                        <content>
                            <HBox spacing="16.0" VBox.vgrow="ALWAYS">
                                <padding><Insets bottom="16" left="0" right="0" top="16" /></padding>
                                <children>

                                    <!-- Panel izquierdo: Tipos de Impuesto -->
                                    <VBox spacing="10.0" minWidth="380.0"
                                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 2);"
                                          HBox.hgrow="NEVER">
                                        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                                        <children>
                                            <Label text="Tipos de Impuesto"
                                                   style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                                            <Separator style="-fx-opacity: 0.5;" />

                                            <StyledTableView fx:id="tableTaxTypes" style="-fx-fixed-cell-size: 44px;" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="colTaxName" prefWidth="135.0" style="-fx-alignment: CENTER;" text="Nombre" />
                                                    <TableColumn fx:id="colTaxRate" prefWidth="85.0" style="-fx-alignment: CENTER;" text="Tasa %" />
                                                    <TableColumn fx:id="colTaxApplies" prefWidth="115.0" style="-fx-alignment: CENTER;" text="Aplica a" />
                                                    <TableColumn fx:id="colTaxDesc" prefWidth="245.0" style="-fx-alignment: CENTER;" text="Descripción" />
                                                </columns>
                                                <columnResizePolicy>
                                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                </columnResizePolicy>
                                            </StyledTableView>

                                            <HBox spacing="10.0">
                                                <children>
                                                    <Button fx:id="btnNewTax" contentDisplay="LEFT" graphicTextGap="12.0"
                                                            mnemonicParsing="false" onAction="#onNewTax" prefHeight="48.0"
                                                            styleClass="mini-card-btn,mini-card-green" text="Nuevo Impuesto">
                                                        <graphic>
                                                            <StackPane alignment="CENTER" minWidth="30.0" minHeight="30.0" maxWidth="30.0" maxHeight="30.0"
                                                                       styleClass="mini-card-chip-green">
                                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="＋" StackPane.alignment="CENTER" />
                                                            </StackPane>
                                                        </graphic>
                                                    </Button>
                                                    <Button fx:id="btnEditTax" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                                                            mnemonicParsing="false" onAction="#onEditTax" prefHeight="48.0"
                                                            styleClass="mini-card-btn,mini-card-orange" text="Editar">
                                                        <graphic>
                                                            <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                                                       styleClass="mini-card-chip-orange">
                                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✎" StackPane.alignment="CENTER" />
                                                            </StackPane>
                                                        </graphic>
                                                    </Button>
                                                    <Button fx:id="btnDeleteTax" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                                                            mnemonicParsing="false" onAction="#onDeleteTax" prefHeight="48.0"
                                                            styleClass="mini-card-btn,mini-card-red" text="Eliminar">
                                                        <graphic>
                                                            <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                                                       styleClass="mini-card-chip-red">
                                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✕" StackPane.alignment="CENTER" />
                                                            </StackPane>
                                                        </graphic>
                                                    </Button>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <!-- Panel derecho: Categorías por Impuesto -->
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                                        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                                        <children>
                                            <Label text="Categorías por Impuesto"
                                                   style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                                            <Label text="Selecciona un impuesto de la izquierda para ver y editar sus categorías"
                                                   style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;" />
                                            <Separator style="-fx-opacity: 0.5;" />

                                            <HBox spacing="10.0">
                                                <children>
                                                    <Button fx:id="btnSelectAll" contentDisplay="LEFT" graphicTextGap="8.0"
                                                            mnemonicParsing="false" onAction="#onSelectAll" prefHeight="36.0"
                                                            styleClass="mini-card-btn,mini-card-green" text="Seleccionar Todas">
                                                        <graphic>
                                                            <StackPane alignment="CENTER" minWidth="22.0" minHeight="22.0" maxWidth="22.0" maxHeight="22.0"
                                                                       styleClass="mini-card-chip-green">
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;" text="✓" StackPane.alignment="CENTER" />
                                                            </StackPane>
                                                        </graphic>
                                                    </Button>
                                                    <Button fx:id="btnDeselectAll" contentDisplay="LEFT" graphicTextGap="8.0"
                                                            mnemonicParsing="false" onAction="#onDeselectAll" prefHeight="36.0"
                                                            styleClass="mini-card-btn,mini-card-gray" text="Quitar Todas">
                                                        <graphic>
                                                            <StackPane alignment="CENTER" minWidth="22.0" minHeight="22.0" maxWidth="22.0" maxHeight="22.0"
                                                                       styleClass="mini-card-chip-gray">
                                                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white;" text="✕" StackPane.alignment="CENTER" />
                                                            </StackPane>
                                                        </graphic>
                                                    </Button>
                                                </children>
                                            </HBox>

                                            <StyledTableView fx:id="tableCategoryAssignment" editable="true" style="-fx-fixed-cell-size: 44px;" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="colAssignCheck" editable="true" prefWidth="60.0" style="-fx-alignment: CENTER;" text="Aplica" />
                                                    <TableColumn fx:id="colAssignCatName" prefWidth="250.0" style="-fx-alignment: CENTER;" text="Categoría" />
                                                </columns>
                                                <columnResizePolicy>
                                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                </columnResizePolicy>
                                            </StyledTableView>

                                            <HBox alignment="CENTER_RIGHT">
                                                <children>
                                                    <Button fx:id="btnSaveAssignment" contentDisplay="LEFT" graphicTextGap="12.0"
                                                            mnemonicParsing="false" onAction="#onSaveAssignment" prefHeight="48.0"
                                                            styleClass="mini-card-btn,mini-card-blue" text="Guardar Asignación">
                                                        <graphic>
                                                            <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                                                       styleClass="mini-card-chip-blue">
                                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✓" StackPane.alignment="CENTER" />
                                                            </StackPane>
                                                        </graphic>
                                                    </Button>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                </children>
                            </HBox>
                        </content>
                    </Tab>

                    <!-- PESTAÑA 2: Márgenes de Utilidad -->
                    <Tab text="Márgenes de Utilidad">
                        <content>
                            <VBox spacing="10.0" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 2);">
                                <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>
                                <children>
                                    <Label text="Márgenes de Utilidad por Categoría"
                                           style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                                    <Separator style="-fx-opacity: 0.5;" />

                                    <HBox spacing="16.0" alignment="CENTER_LEFT">
                                        <children>
                                            <Label styleClass="lbl-campo" text="Categoría" />
                                            <ComboBox fx:id="comboCat" maxWidth="250.0"
                                                      prefHeight="40.0" promptText="Seleccionar..."
                                                      styleClass="input-moderno" />
                                            <Label styleClass="lbl-campo" text="Utilidad (%)" />
                                            <TextField fx:id="txtMargen" prefHeight="40.0"
                                                       prefWidth="100.0" promptText="Ej: 30"
                                                       styleClass="input-moderno" />
                                            <Button fx:id="btnGuardarMargen" contentDisplay="LEFT" graphicTextGap="12.0"
                                                    mnemonicParsing="false" onAction="#guardarMargen" prefHeight="40.0"
                                                    styleClass="mini-card-btn,mini-card-green" text="Guardar">
                                                <graphic>
                                                    <StackPane alignment="CENTER" minWidth="24.0" minHeight="24.0" maxWidth="24.0" maxHeight="24.0"
                                                               styleClass="mini-card-chip-green">
                                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" text="✓" StackPane.alignment="CENTER" />
                                                    </StackPane>
                                                </graphic>
                                            </Button>
                                        </children>
                                    </HBox>

                                    <StyledTableView fx:id="tableCategories" editable="false"
                                                     style="-fx-fixed-cell-size: 40px;"
                                                     styleClass="tabla-readonly"
                                                     VBox.vgrow="ALWAYS">
                                        <columns>
                                            <TableColumn fx:id="colCategoriaNombre" prefWidth="380.0" text="Categoría" />
                                            <TableColumn fx:id="colMargen" prefWidth="220.0" text="Utilidad (%)" />
                                        </columns>
                                        <columnResizePolicy>
                                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                        </columnResizePolicy>
                                    </StyledTableView>
                                </children>
                            </VBox>
                        </content>
                    </Tab>

                </tabs>
            </TabPane>

        </children>
    </VBox>
</AnchorPane>
