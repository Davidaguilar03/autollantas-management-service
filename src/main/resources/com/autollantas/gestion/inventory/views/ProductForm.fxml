<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="modal-overlay" stylesheets="@../../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.inventory.controller.ProductFormController">

    <VBox alignment="TOP_CENTER" maxHeight="500" maxWidth="680" spacing="18" styleClass="card-form">

        <HBox alignment="CENTER_LEFT">
            <VBox prefHeight="31.0" prefWidth="185.0" spacing="4">
                <Label fx:id="lblTitulo" styleClass="lbl-titulo" text="Nuevo Producto" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#cerrarVentana" prefHeight="26.0" prefWidth="42.0" styleClass="btn-cerrar" text="✕" />
        </HBox>

        <Separator style="-fx-opacity: 0.5;" />

        <GridPane hgap="20.0" vgap="18.0">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="165" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="165" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <!-- Fila 0: Código -->
            <Label styleClass="lbl-campo" text="Código" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtCodigo" promptText="REF-001" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <!-- Fila 1: Categoría (ancho completo) -->
            <Label styleClass="lbl-campo" text="Categoría" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="comboCategoria" maxWidth="Infinity" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="1" />

            <!-- Fila 2: Descripción -->
            <Label styleClass="lbl-campo" text="Descripción" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="txtDescripcion" promptText="Ej: Llanta Michelin 255/50" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2" />

            <!-- Fila 3: Precio de Compra sin IVA | IVA del Producto -->
            <Label styleClass="lbl-campo" text="Precio de Compra sin IVA ($)" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="txtPurchaseCost" promptText="Ej: 238000" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label styleClass="lbl-campo" text="IVA del Producto (19%)" GridPane.columnIndex="2" GridPane.rowIndex="3" />
            <TextField fx:id="txtTaxAmount" editable="false" styleClass="input-readonly" GridPane.columnIndex="3" GridPane.rowIndex="3" />

            <!-- Fila 4: Stock -->
            <Label styleClass="lbl-campo" text="Stock Inicial" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <Spinner fx:id="spinnerStock" editable="true" maxWidth="149.0" prefHeight="40.0" prefWidth="149.0" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
            <Button cancelButton="true" contentDisplay="LEFT" graphicTextGap="12.0"
                    mnemonicParsing="false" onAction="#cerrarVentana" prefHeight="48.0"
                    styleClass="mini-card-btn,mini-card-gray" text="Cancelar">
                <graphic>
                    <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                               styleClass="mini-card-chip-gray">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✗" StackPane.alignment="CENTER" />
                    </StackPane>
                </graphic>
            </Button>
            <Button defaultButton="true" contentDisplay="LEFT" graphicTextGap="12.0"
                    mnemonicParsing="false" onAction="#guardarProducto" prefHeight="48.0"
                    styleClass="mini-card-btn,mini-card-green" text="Guardar Cambios">
                <graphic>
                    <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                               styleClass="mini-card-chip-green">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✓" StackPane.alignment="CENTER" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>

    </VBox>
</StackPane>
