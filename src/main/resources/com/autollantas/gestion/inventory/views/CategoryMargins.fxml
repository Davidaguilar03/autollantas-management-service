<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="modal-overlay" stylesheets="@../../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.inventory.controller.CategoryMarginsController">

    <VBox alignment="TOP_CENTER" maxHeight="480" maxWidth="700" spacing="15" styleClass="card-form">
        <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="20.0" />
        </padding>

        <HBox alignment="CENTER_LEFT">
            <Label styleClass="lbl-titulo" text="Configurar Utilidades" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#cerrarVentana" styleClass="btn-cerrar" text="✕" />
        </HBox>

        <Separator style="-fx-opacity: 0.5;" />

        <HBox alignment="BOTTOM_LEFT" spacing="15">
            <VBox spacing="5">
                <Label styleClass="lbl-campo" text="Categoría" />
                <ComboBox fx:id="comboCat" prefWidth="280" />
            </VBox>
            <VBox spacing="5">
                <Label styleClass="lbl-campo" text="Utilidad (%%)" />
                <TextField fx:id="txtMargen" prefWidth="120" promptText="Ej: 30" styleClass="input-moderno" />
            </VBox>
            <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardar" prefHeight="32.0" styleClass="btn-success" text="Guardar" />
        </HBox>

        <Separator style="-fx-opacity: 0.5;" />

        <TableView fx:id="tableCategories" prefHeight="220" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCategoriaNombre" prefWidth="380.0" text="Categoría" />
                <TableColumn fx:id="colMargen" prefWidth="220.0" text="Utilidad (%%)" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

    </VBox>
</StackPane>
