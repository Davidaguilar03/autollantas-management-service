<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import com.autollantas.gestion.shared.util.StyledTableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #f0f2f5;" styleClass="main-background" stylesheets="@../../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.inventory.controller.ProductsController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <VBox>
                    <children>
                        <Label styleClass="view-title" text="Inventario de Productos" />
                    </children>
                </VBox>

                <VBox styleClass="filter-card">
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../../images/buscar.png" />
                                    </image>
                                </ImageView>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Filtros de Búsqueda" />
                            </children>
                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin>
                        </HBox>

                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <GridPane hgap="15.0" vgap="10.0" HBox.hgrow="ALWAYS">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" prefWidth="150.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" prefWidth="150.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" prefWidth="160.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" prefWidth="160.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" prefWidth="160.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" prefWidth="160.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints minHeight="55.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="55.0" vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    <children>

                                        <!-- Fila 1: Categoría (col 0) | Código (col 1) | Descripción (cols 2-3) | Marca (cols 4-5) -->
                                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Categoría:" />
                                                <ComboBox fx:id="comboCategoria" maxWidth="Infinity" promptText="Todas" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Código:" />
                                                <TextField fx:id="txtCodigo" promptText="Ej: LF01..." styleClass="text-field-search" maxWidth="Infinity" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="0">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Descripción:" />
                                                <TextField fx:id="txtDescripcion" promptText="Ej: 225/45R18" styleClass="text-field-search" maxWidth="Infinity" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="4.0" GridPane.columnIndex="4" GridPane.columnSpan="2" GridPane.rowIndex="0">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #888;" text="Marca / Tipo:" />
                                                <TextField fx:id="txtMarca" promptText="Ej: Laufenn" styleClass="text-field-search" maxWidth="Infinity" />
                                            </children>
                                        </VBox>

                                        <!-- Fila 2: Precio Compra s/IVA (cols 0-2) | Precio Sugerido (cols 3-5) -->
                                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="1">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #2980b9;" text="P. Compra s/IVA ($):" />
                                                <HBox spacing="6.0">
                                                    <children>
                                                        <TextField fx:id="txtPrecioCompraMin" promptText="Mín" styleClass="text-field-search" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                                                        <TextField fx:id="txtPrecioCompraMax" promptText="Máx" styleClass="text-field-search" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="4.0" GridPane.columnIndex="3" GridPane.columnSpan="3" GridPane.rowIndex="1">
                                            <children>
                                                <Label style="-fx-font-size: 11px; -fx-text-fill: #e67e22;" text="Precio Sugerido ($):" />
                                                <HBox spacing="6.0">
                                                    <children>
                                                        <TextField fx:id="txtPrecioMin" promptText="Mín" styleClass="text-field-search" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                                                        <TextField fx:id="txtPrecioMax" promptText="Máx" styleClass="text-field-search" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </GridPane>

                                <Separator orientation="VERTICAL" prefHeight="110.0" prefWidth="0.0" />

                                <VBox alignment="CENTER" minWidth="140.0" prefWidth="140.0" spacing="10.0" HBox.hgrow="NEVER">
                                    <children>
                                        <Button contentDisplay="LEFT" graphicTextGap="10.0" maxWidth="Infinity"
                                                mnemonicParsing="false" onAction="#btnBuscarClick" prefHeight="48.0"
                                                styleClass="mini-card-btn,mini-card-blue" text="Filtrar">
                                            <graphic>
                                                <StackPane alignment="CENTER" minWidth="36.0" minHeight="36.0" maxWidth="36.0" maxHeight="36.0"
                                                           styleClass="mini-card-chip-blue">
                                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="⊟" StackPane.alignment="CENTER" />
                                                </StackPane>
                                            </graphic>
                                        </Button>
                                        <Button contentDisplay="LEFT" graphicTextGap="10.0" maxWidth="Infinity"
                                                mnemonicParsing="false" onAction="#btnLimpiarFiltrosClick" prefHeight="48.0"
                                                styleClass="mini-card-btn,mini-card-gray" text="Limpiar">
                                            <graphic>
                                                <StackPane alignment="CENTER" minWidth="36.0" minHeight="36.0" maxWidth="36.0" maxHeight="36.0"
                                                           styleClass="mini-card-chip-gray">
                                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="↺" StackPane.alignment="CENTER" />
                                                </StackPane>
                                            </graphic>
                                        </Button>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <StyledTableView fx:id="tablaProductos" prefHeight="362.0" prefWidth="1180.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colCategoria" prefWidth="144.3333282470703" style="-fx-alignment: CENTER;" text="Categoria producto" />
                        <TableColumn fx:id="colCodigo" prefWidth="135.33331298828125" style="-fx-alignment: CENTER;" text="Codigo" />
                        <TableColumn fx:id="colDescripcion" prefWidth="359.66668701171875" style="-fx-alignment: CENTER;" text="Descripcion" />

                        <TableColumn fx:id="colPurchaseCost" prefWidth="130.0" style="-fx-alignment: CENTER;" text="P. Compra s/IVA" />
                        <TableColumn fx:id="colTaxAmount" prefWidth="120.0" style="-fx-alignment: CENTER;" text="IVA Producto" />
                        <TableColumn fx:id="colMinSalePrice" prefWidth="140.0" style="-fx-alignment: CENTER;" text="Precio Mín. Venta" />
                        <TableColumn fx:id="colSuggestedPrice" prefWidth="130.0" style="-fx-alignment: CENTER;" text="Precio Sugerido" />

                        <TableColumn fx:id="colExistencias" prefWidth="79.0" style="-fx-alignment: CENTER;" text="Existencias" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </StyledTableView>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Button contentDisplay="LEFT" graphicTextGap="12.0" mnemonicParsing="false"
                                onAction="#btnNuevoProductoClick" prefHeight="48.0"
                                styleClass="mini-card-btn,mini-card-green" text="Nuevo Producto">
                            <graphic>
                                <StackPane alignment="CENTER" minWidth="30.0" minHeight="30.0" maxWidth="30.0" maxHeight="30.0"
                                           styleClass="mini-card-chip-green">
                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="＋" StackPane.alignment="CENTER" />
                                </StackPane>
                            </graphic>
                        </Button>

                        <Button fx:id="btnEditar" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                                mnemonicParsing="false" onAction="#btnEditarClick" prefHeight="48.0"
                                styleClass="mini-card-btn,mini-card-orange" text="Editar">
                            <graphic>
                                <StackPane minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                           styleClass="mini-card-chip-orange">
                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✎" />
                                </StackPane>
                            </graphic>
                        </Button>

                        <Button fx:id="btnEliminar" contentDisplay="LEFT" disable="true" graphicTextGap="12.0"
                                mnemonicParsing="false" onAction="#btnEliminarClick" prefHeight="48.0"
                                styleClass="mini-card-btn,mini-card-red" text="Eliminar">
                            <graphic>
                                <StackPane minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                           styleClass="mini-card-chip-red">
                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✕" />
                                </StackPane>
                            </graphic>
                        </Button>

                        <Region HBox.hgrow="ALWAYS" />

<Button fx:id="btnCategorias" contentDisplay="LEFT" graphicTextGap="12.0"
                                mnemonicParsing="false" onAction="#btnCategoriasClick"
                                prefHeight="48.0" styleClass="mini-card-btn,mini-card-purple" text="Categorías">
                            <graphic>
                                <StackPane minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                           styleClass="mini-card-chip-purple">
                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 3 0;" text="≡" />
                                </StackPane>
                            </graphic>
                        </Button>
                        <Label fx:id="lblInfoRegistros" style="-fx-font-weight: bold;" text="Cargando..." textFill="#666666">
                            <padding>
                                <Insets right="10.0" />
                            </padding>
                        </Label>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
