<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import com.autollantas.gestion.shared.util.StyledTableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" prefHeight="800.0" prefWidth="1200.0" styleClass="main-background" stylesheets="@../../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.inventory.controller.StockAlertsController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="30.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label styleClass="view-title" text="Centro de Control de Stock" />
                            </children>
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <HBox spacing="15.0">
                            <VBox styleClass="kpi-card, kpi-card-critical">
                                <Label styleClass="kpi-label" text="ALERTAS CRÍTICAS" />
                                <Label fx:id="lblKpiCritico" style="-fx-text-fill: #e74c3c;" styleClass="kpi-value" text="0" />
                            </VBox>
                            <VBox styleClass="kpi-card, kpi-card-warning">
                                <Label styleClass="kpi-label" text="ADVERTENCIAS" />
                                <Label fx:id="lblKpiAdvertencia" style="-fx-text-fill: #f1c40f;" styleClass="kpi-value" text="0" />
                            </VBox>
                            <VBox styleClass="kpi-card, kpi-card-ok">
                                <Label styleClass="kpi-label" text="STOCK SALUDABLE" />
                                <Label fx:id="lblKpiSaludable" style="-fx-text-fill: #27ae60;" styleClass="kpi-value" text="0" />
                            </VBox>
                        </HBox>
                    </children>
                </HBox>

                <TabPane fx:id="tabPane" styleClass="modern-tab-pane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <Tab text="MONITOR DE ALERTAS">
                            <content>
                                <VBox spacing="15.0">
                                    <padding> <Insets top="15.0" /> </padding>

                                    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 10 20;" styleClass="card-panel">
                                        <ComboBox fx:id="comboFiltroCategoria" prefHeight="32.0" prefWidth="180.0" promptText="Todas las categorías" style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-background-radius: 4; -fx-border-radius: 4;" />

                                        <ComboBox fx:id="comboFiltroEstado" prefHeight="32.0" prefWidth="150.0" promptText="Todos los estados" style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-background-radius: 4; -fx-border-radius: 4;" />

                                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 4; -fx-background-radius: 4;" HBox.hgrow="ALWAYS">
                                            <children>
                                                <ImageView fitHeight="16.0" fitWidth="16.0" opacity="0.5" pickOnBounds="true" preserveRatio="true">
                                                    <image> <Image url="@../../images/buscar.png" /> </image>
                                                    <HBox.margin> <Insets left="10.0" /> </HBox.margin>
                                                </ImageView>
                                                <TextField fx:id="txtBuscarProducto" prefHeight="34.0" prefWidth="444.0" promptText="Buscar referencia o código..." style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
                                                    <HBox.margin> <Insets left="10.0" right="10.0" /> </HBox.margin>
                                                </TextField>
                                            </children>
                                        </HBox>

                                        <Button contentDisplay="LEFT" graphicTextGap="12.0"
                                                mnemonicParsing="false" onAction="#btnRefreshClick" prefHeight="48.0"
                                                styleClass="mini-card-btn,mini-card-gray" text="Actualizar">
                                            <graphic>
                                                <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                                           styleClass="mini-card-chip-gray">
                                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="↺" StackPane.alignment="CENTER" />
                                                </StackPane>
                                            </graphic>
                                        </Button>
                                    </HBox>

                                    <StackPane VBox.vgrow="ALWAYS">
                                        <StyledTableView fx:id="tablaAlertas" style="-fx-fixed-cell-size: 50px;">
                                            <columns>
                                                <TableColumn fx:id="colCodigo" prefWidth="100.0" style="-fx-alignment: CENTER;" text="CÓDIGO" />
                                                <TableColumn fx:id="colProducto" prefWidth="300.0" text="PRODUCTO" />
                                                <TableColumn fx:id="colCategoria" prefWidth="150.0" style="-fx-alignment: CENTER;" text="CATEGORÍA" />
                                                <TableColumn fx:id="colStockActual" prefWidth="100.0" style="-fx-alignment: CENTER; -fx-font-weight: bold;" text="STOCK" />
                                                <TableColumn fx:id="colEstadoVisual" prefWidth="140.0" style="-fx-alignment: CENTER;" text="ESTADO" />
                                            </columns>
                                            <columnResizePolicy> <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /> </columnResizePolicy>
                                        </StyledTableView>

                                        <ProgressIndicator fx:id="loaderScroll" maxHeight="20.0" maxWidth="20.0" visible="false" StackPane.alignment="BOTTOM_RIGHT">
                                            <StackPane.margin> <Insets bottom="35.0" right="20.0" /> </StackPane.margin>
                                        </ProgressIndicator>
                                    </StackPane>
                                </VBox>
                            </content>
                        </Tab>

                        <Tab text="CONFIGURACIÓN DE REGLAS">
                            <content>
                                <AnchorPane>
                                    <padding> <Insets top="15.0" /> </padding>
                                    <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

                                        <!-- Encabezado -->
                                        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card-panel">
                                            <VBox spacing="4.0">
                                                <Label style="-fx-font-weight: bold; -fx-font-size: 15px;" text="Umbrales de alerta por categoría" />
                                                <Label styleClass="text-muted" text="Ajusta las cantidades mínimas de stock para cada categoría. Los cambios se aplican al guardar." />
                                            </VBox>
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Button onAction="#btnGuardarConfiguracionClick"
                                                    style="-fx-background-color: #4F83CC; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 22;"
                                                    text="Aplicar cambios">
                                                <graphic>
                                                    <ImageView fitHeight="22.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                                                        <image> <Image url="@../../images/save.png" /> </image>
                                                    </ImageView>
                                                </graphic>
                                            </Button>
                                        </HBox>

                                        <!-- Leyenda de colores -->
                                        <HBox alignment="CENTER_LEFT" spacing="30.0" style="-fx-padding: 0 4px;">
                                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                <Label style="-fx-background-color: #fef3e2; -fx-border-color: #e8a84c; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1.5; -fx-padding: 5 14; -fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #b7630a;" text="ADVERTENCIA" />
                                                <Label styleClass="text-muted" text="Si el stock baja a este valor o menos, el producto aparece en amarillo." />
                                            </HBox>
                                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                <Label style="-fx-background-color: #fdf0ef; -fx-border-color: #e07070; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1.5; -fx-padding: 5 14; -fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #c0392b;" text="CRITICO" />
                                                <Label styleClass="text-muted" text="Si el stock baja a este valor o menos, el producto aparece en rojo." />
                                            </HBox>
                                        </HBox>

                                        <!-- Tabla -->
                                        <StyledTableView fx:id="tablaConfiguracion" editable="false" VBox.vgrow="ALWAYS" style="-fx-fixed-cell-size: 46px;">
                                            <columns>
                                                <TableColumn fx:id="colConfCategoria" prefWidth="220.0" text="CATEGORÍA" />
                                                <TableColumn fx:id="colConfAmarillo" prefWidth="280.0" style="-fx-alignment: CENTER;" text="ADVERTENCIA  —  stock mínimo" />
                                                <TableColumn fx:id="colConfRojo" prefWidth="280.0" style="-fx-alignment: CENTER;" text="CRÍTICO  —  stock de peligro" />
                                            </columns>
                                            <columnResizePolicy> <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /> </columnResizePolicy>
                                        </StyledTableView>

                                    </VBox>
                                </AnchorPane>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>

                <HBox alignment="CENTER_RIGHT">
                    <Label fx:id="lblInfoScroll" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="Cargando datos..." />
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>