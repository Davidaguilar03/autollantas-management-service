<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="modal-overlay" stylesheets="@../../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.inventory.controller.TaxFormController">

    <VBox alignment="TOP_CENTER" maxHeight="400" maxWidth="480" spacing="20" styleClass="card-form">

        <HBox alignment="CENTER_LEFT">
            <VBox prefHeight="31.0" prefWidth="200.0" spacing="4">
                <Label fx:id="lblTitulo" styleClass="lbl-titulo" text="Nuevo Impuesto" />
            </VBox>
            <Region prefHeight="31.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button onAction="#cancelar" prefHeight="26.0" prefWidth="42.0" styleClass="btn-cerrar" text="✕" />
        </HBox>

        <Separator style="-fx-opacity: 0.5;" />

        <GridPane hgap="25.0" vgap="18.0">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="NEVER" minWidth="110" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>

            <Label styleClass="lbl-campo" text="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtName" promptText="Ej: IVA 19%" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label styleClass="lbl-campo" text="Tasa (%)" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtRate" promptText="19.0" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label styleClass="lbl-campo" text="Descripción" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="txtDescription" promptText="Descripción opcional" styleClass="input-moderno" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label styleClass="lbl-campo" text="Aplica a" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <HBox spacing="15.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <children>
                    <RadioButton fx:id="rbProduct" text="Producto">
                        <toggleGroup>
                            <ToggleGroup fx:id="toggleApplies" />
                        </toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="rbTransaction" text="Transacción" toggleGroup="$toggleApplies" />
                </children>
            </HBox>
        </GridPane>

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="btnCancelar" cancelButton="true" contentDisplay="LEFT" graphicTextGap="12.0"
                    mnemonicParsing="false" onAction="#cancelar" prefHeight="48.0"
                    styleClass="mini-card-btn,mini-card-gray" text="Cancelar">
                <graphic>
                    <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                               styleClass="mini-card-chip-gray">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✗" StackPane.alignment="CENTER" />
                    </StackPane>
                </graphic>
            </Button>
            <Button fx:id="btnGuardar" defaultButton="true" contentDisplay="LEFT" graphicTextGap="12.0"
                    mnemonicParsing="false" onAction="#guardar" prefHeight="48.0"
                    styleClass="mini-card-btn,mini-card-green" text="Guardar">
                <graphic>
                    <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                               styleClass="mini-card-chip-green">
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✓" StackPane.alignment="CENTER" />
                    </StackPane>
                </graphic>
            </Button>
        </HBox>

    </VBox>
</StackPane>
