<?xml version="1.0" encoding="UTF-8"?>

<?import com.autollantas.gestion.shared.util.StyledTableView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" focusTraversable="false" hbarPolicy="NEVER" style="-fx-background-color: #f5f6fa; -fx-background: #f5f6fa;" stylesheets="@../../styles/styles.css" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.autollantas.gestion.reporting.controller.DashboardController">

    <content>
        <VBox spacing="12.0" style="-fx-background-color: #f5f6fa;">
            <padding><Insets bottom="19.0" left="24.0" right="24.0" top="16.0" /></padding>

            <!-- Encabezado -->
            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="3.0">
                    <Label text="Panel de Control">
                        <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                    <Label style="-fx-text-fill: #a0adb8; -fx-font-size: 12px;" text="Resumen general del negocio" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-border-color: #eaecf2; -fx-border-radius: 10; -fx-border-width: 1;">
                    <padding><Insets bottom="8.0" left="14.0" right="14.0" top="8.0" /></padding>
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #a0adb8; -fx-font-size: 11px;" text="PERIODO" />
                    <ComboBox fx:id="comboPeriodo" prefWidth="175.0" style="-fx-background-color: #f7f8fc; -fx-border-color: #eaecf2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-width: 1;" />
                    <HBox fx:id="boxFechasPersonalizadas" alignment="CENTER_LEFT" managed="false" spacing="8.0" visible="false">
                        <Label style="-fx-text-fill: #a0adb8; -fx-font-size: 11px;" text="Desde" />
                        <DatePicker fx:id="dateDesde" prefWidth="145.0" promptText="dd/mm/aaaa" />
                        <Label style="-fx-text-fill: #a0adb8; -fx-font-size: 11px;" text="Hasta" />
                        <DatePicker fx:id="dateHasta" prefWidth="145.0" promptText="dd/mm/aaaa" />
                        <Button fx:id="btnAplicarFechas" contentDisplay="LEFT" graphicTextGap="12.0"
                                mnemonicParsing="false" prefHeight="48.0"
                                styleClass="mini-card-btn,mini-card-blue" text="Aplicar">
                            <graphic>
                                <StackPane alignment="CENTER" minWidth="28.0" minHeight="28.0" maxWidth="28.0" maxHeight="28.0"
                                           styleClass="mini-card-chip-blue">
                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="✓" StackPane.alignment="CENTER" />
                                </StackPane>
                            </graphic>
                        </Button>
                    </HBox>
                </HBox>
            </HBox>

            <!-- Fila 1: KPIs de período -->
            <GridPane hgap="14.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                </columnConstraints>
                <rowConstraints><RowConstraints minHeight="94.0" /></rowConstraints>

                <!-- Ingresos -->
                <VBox spacing="10.0" style="-fx-padding: 13 18 13 18;" styleClass="dashboard-card,card-green">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-green">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/ingresos.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="INGRESOS" />
                    </HBox>
                    <Label fx:id="lblIngresos" styleClass="card-value" text="—">
                        <tooltip><Tooltip text="Total de ventas e ingresos ocasionales en el periodo seleccionado." wrapText="true" /></tooltip>
                    </Label>
                </VBox>

                <!-- Gastos -->
                <VBox spacing="10.0" style="-fx-padding: 13 18 13 18;" styleClass="dashboard-card,card-red" GridPane.columnIndex="1">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-red">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/gastos.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="GASTOS" />
                    </HBox>
                    <Label fx:id="lblGastos" styleClass="card-value" text="—">
                        <tooltip><Tooltip text="Total de gastos operativos registrados en el periodo seleccionado." wrapText="true" /></tooltip>
                    </Label>
                </VBox>

                <!-- Costos -->
                <VBox spacing="10.0" style="-fx-padding: 13 18 13 18;" styleClass="dashboard-card,card-yellow" GridPane.columnIndex="2">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-yellow">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/costos.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="COSTOS" />
                    </HBox>
                    <Label fx:id="lblCostos" styleClass="card-value" text="—">
                        <tooltip><Tooltip text="Total de compras a proveedores (costo de mercancía) en el periodo seleccionado." wrapText="true" /></tooltip>
                    </Label>
                </VBox>

                <!-- Resultado neto -->
                <VBox spacing="10.0" style="-fx-padding: 13 18 13 18;" styleClass="dashboard-card,card-purple" GridPane.columnIndex="3">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-purple">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/resultados.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="RESULTADO NETO" />
                    </HBox>
                    <Label fx:id="lblNeto" styleClass="card-value" text="—">
                        <tooltip><Tooltip text="Ingresos menos Gastos y Costos del periodo. Verde = ganancia, Rojo = pérdida." wrapText="true" /></tooltip>
                    </Label>
                </VBox>
            </GridPane>

            <!-- Fila 2: KPIs globales -->
            <GridPane hgap="14.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="190.0" percentWidth="25.0" />
                </columnConstraints>
                <rowConstraints><RowConstraints minHeight="94.0" /></rowConstraints>

                <!-- Por cobrar -->
                <VBox spacing="10.0" style="-fx-padding: 13 18 13 18;" styleClass="dashboard-card,card-blue">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-blue">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/cobrar.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="POR COBRAR" />
                    </HBox>
                    <Label fx:id="lblPorCobrar" styleClass="card-value" text="0">
                        <tooltip><Tooltip text="Suma de ventas con estado PENDIENTE. No depende del periodo seleccionado." wrapText="true" /></tooltip>
                    </Label>
                </VBox>

                <!-- Por pagar -->
                <VBox spacing="10.0" style="-fx-padding: 13 18 13 18;" styleClass="dashboard-card,card-pink" GridPane.columnIndex="1">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-pink">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/pagar.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="POR PAGAR" />
                    </HBox>
                    <Label fx:id="lblPorPagar" styleClass="card-value" text="0">
                        <tooltip><Tooltip text="Suma de compras con estado PENDIENTE. No depende del periodo seleccionado." wrapText="true" /></tooltip>
                    </Label>
                </VBox>

                <!-- Saldo total -->
                <VBox spacing="10.0" style="-fx-padding: 13 18 13 18;" styleClass="dashboard-card,card-cyan" GridPane.columnIndex="2">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-cyan">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/saldo.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="SALDO TOTAL" />
                    </HBox>
                    <Label fx:id="lblSaldo" styleClass="card-value" text="0">
                        <tooltip><Tooltip text="Suma del saldo actual de todas las cuentas registradas (caja, bancos, etc.)." wrapText="true" /></tooltip>
                    </Label>
                </VBox>

                <!-- Alertas de stock -->
                <VBox onMouseClicked="#verAlertasStock" spacing="10.0" style="-fx-padding: 13 18 13 18; -fx-cursor: hand;" styleClass="dashboard-card,card-orange" GridPane.columnIndex="3">
                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <StackPane maxHeight="46.0" maxWidth="46.0" minHeight="46.0" minWidth="46.0" styleClass="icon-chip-orange">
                            <ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@../../images/alerta.png" /></image></ImageView>
                        </StackPane>
                        <Label styleClass="card-label" text="ALERTAS STOCK" />
                    </HBox>
                    <Label fx:id="lblAlertas" styleClass="card-value" text="—">
                        <tooltip><Tooltip text="Productos con stock igual o por debajo del mínimo definido. Haz clic para ver el detalle." wrapText="true" /></tooltip>
                    </Label>
                </VBox>
            </GridPane>

            <!-- Fila 3: Tabla + Panel lateral -->
            <HBox spacing="14.0" VBox.vgrow="ALWAYS">

                <!-- Tabla de movimientos -->
                <VBox minWidth="460.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 12, 0, 0, 3);" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="13.0" left="18.0" right="18.0" top="13.0" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="3.0">
                            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Últimos movimientos" />
                        </VBox>
                    </HBox>

                    <Label style="-fx-font-size: 10px; -fx-text-fill: #b0bac6; -fx-padding: 0 0 2 0;" text="Doble clic en un movimiento para ir a su módulo." />

                    <StyledTableView fx:id="tablaMovimientos" prefHeight="272.0" style="-fx-fixed-cell-size: 34px;" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colFecha" prefWidth="88.0" style="-fx-alignment: CENTER;" text="Fecha" />
                            <TableColumn fx:id="colTipo" prefWidth="82.0" style="-fx-alignment: CENTER;" text="Tipo" />
                            <TableColumn fx:id="colConcepto" prefWidth="240.0" style="-fx-alignment: CENTER-LEFT;" text="Concepto" />
                            <TableColumn fx:id="colCuenta" prefWidth="110.0" style="-fx-alignment: CENTER-LEFT;" text="Cuenta" />
                            <TableColumn fx:id="colMonto" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" text="Monto" />
                        </columns>
                    </StyledTableView>
                </VBox>

                <!-- Panel lateral -->
                <VBox minWidth="290.0" prefWidth="310.0" spacing="14.0" HBox.hgrow="SOMETIMES">

                    <!-- Acciones rápidas -->
                    <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 12, 0, 0, 3);">
                        <padding><Insets bottom="13.0" left="18.0" right="18.0" top="13.0" /></padding>
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2d3748;" text="Acciones rápidas" />
                        <Region maxHeight="1.0" minHeight="1.0" style="-fx-background-color: #f0f2f7;" />
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50.0" />
                                <ColumnConstraints percentWidth="50.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="52.0" />
                                <RowConstraints minHeight="52.0" />
                            </rowConstraints>
                            <Button contentDisplay="GRAPHIC_ONLY" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                    mnemonicParsing="false" onAction="#actionNuevaVenta" prefHeight="56.0" prefWidth="115.0"
                                    styleClass="mini-card-btn,mini-card-green">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                                        <StackPane alignment="CENTER" minWidth="24.0" minHeight="24.0" maxWidth="24.0" maxHeight="24.0"
                                                   styleClass="mini-card-chip-green">
                                            <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true" StackPane.alignment="CENTER">
                                                <image><Image url="@../../images/cuentas.png" /></image>
                                                <effect><ColorAdjust brightness="1.0" saturation="-1.0" /></effect>
                                            </ImageView>
                                        </StackPane>
                                        <VBox alignment="CENTER_LEFT" spacing="0.0">
                                            <Label text="Nueva" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                            <Label text="Venta" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button contentDisplay="GRAPHIC_ONLY" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                    mnemonicParsing="false" onAction="#actionNuevaCompra" prefHeight="56.0" prefWidth="115.0"
                                    styleClass="mini-card-btn,mini-card-blue" GridPane.columnIndex="1">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                                        <StackPane alignment="CENTER" minWidth="24.0" minHeight="24.0" maxWidth="24.0" maxHeight="24.0"
                                                   styleClass="mini-card-chip-blue">
                                            <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true" StackPane.alignment="CENTER">
                                                <image><Image url="@../../images/nuevacompra.png" /></image>
                                                <effect><ColorAdjust brightness="1.0" saturation="-1.0" /></effect>
                                            </ImageView>
                                        </StackPane>
                                        <VBox alignment="CENTER_LEFT" spacing="0.0">
                                            <Label text="Nueva" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                            <Label text="Compra" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button contentDisplay="GRAPHIC_ONLY" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                    mnemonicParsing="false" onAction="#actionNuevoGasto" prefHeight="56.0" prefWidth="115.0"
                                    styleClass="mini-card-btn,mini-card-red" GridPane.rowIndex="1">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                                        <StackPane alignment="CENTER" minWidth="24.0" minHeight="24.0" maxWidth="24.0" maxHeight="24.0"
                                                   styleClass="mini-card-chip-red">
                                            <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true" StackPane.alignment="CENTER">
                                                <image><Image url="@../../images/gastar.png" /></image>
                                                <effect><ColorAdjust brightness="1.0" saturation="-1.0" /></effect>
                                            </ImageView>
                                        </StackPane>
                                        <VBox alignment="CENTER_LEFT" spacing="0.0">
                                            <Label text="Nuevo" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                            <Label text="Gasto" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </Button>
                            <Button contentDisplay="GRAPHIC_ONLY" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                    mnemonicParsing="false" onAction="#actionNuevoIngreso" prefHeight="56.0" prefWidth="115.0"
                                    styleClass="mini-card-btn,mini-card-teal" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <graphic>
                                    <HBox alignment="CENTER_LEFT" spacing="8.0">
                                        <StackPane alignment="CENTER" minWidth="24.0" minHeight="24.0" maxWidth="24.0" maxHeight="24.0"
                                                   styleClass="mini-card-chip-teal">
                                            <ImageView fitHeight="16.0" fitWidth="16.0" preserveRatio="true" StackPane.alignment="CENTER">
                                                <image><Image url="@../../images/ingresar.png" /></image>
                                                <effect><ColorAdjust brightness="1.0" saturation="-1.0" /></effect>
                                            </ImageView>
                                        </StackPane>
                                        <VBox alignment="CENTER_LEFT" spacing="0.0">
                                            <Label text="Nuevo" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                            <Label text="Ingreso" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a5568;" />
                                        </VBox>
                                    </HBox>
                                </graphic>
                            </Button>
                        </GridPane>
                    </VBox>

                    <!-- Centro de Reportes -->
                    <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 12, 0, 0, 3);" VBox.vgrow="ALWAYS">
                        <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>

                        <Label text="Centro de Reportes" textFill="#34495e">
                            <font><Font name="System Bold" size="16.0" /></font>
                        </Label>

                        <Button fx:id="btnCrearReporte" alignment="CENTER" contentDisplay="TOP" graphicTextGap="14.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#abrirDialogoReportes" prefHeight="160.0" prefWidth="378.0" styleClass="btn-reporte-dashed" text="Crear Nuevo Reporte" textAlignment="CENTER" textOverrun="WORD_ELLIPSIS" VBox.vgrow="ALWAYS">
                            <font><Font name="System Bold" size="20.0" /></font>
                            <graphic>
                                <ImageView fx:id="imgReporteAnimada" fitHeight="59.0" fitWidth="59.0" opacity="0.7" pickOnBounds="true" preserveRatio="true" smooth="true">
                                    <image><Image url="@../../images/reportfile.png" /></image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </VBox>

                </VBox>
            </HBox>

        </VBox>
    </content>
</ScrollPane>
